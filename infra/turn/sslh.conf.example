# sslh: TLS/protocol multiplexer on :443. Routes by SNI/probe to:
#   - turn.<your-domain> → coturn TLS on :5349 (TURN-over-TLS)
#   - everything else (HTTPS, anyprot) → NPM on :8444 → web/api/conduwuit
#
# Copy this file to ``sslh.conf`` next to it and fill in the marked
# __SET_*__ values. The live ``sslh.conf`` is gitignored.
#
# Required substitutions:
#   __SET_HOST_IP__       Internal/loopback IP that sslh forwards to. On
#                         a single-host deploy where coturn + NPM run on
#                         the same box use 127.0.0.1. On a split deploy
#                         use the LAN/internal IP of the upstream host.
#   __SET_TURN_SNI__      Public hostname that ICE clients resolve to the
#                         coturn relay (e.g. ``turn.example.com``). sslh
#                         routes any TLS connection whose SNI matches
#                         this hostname to coturn on :5349.
#
# 2026-05-12: ``keepalive: true`` was added after a 25-day uptime wedge.
# Default sslh leaves forwarded TCP sockets without keepalives, so when
# a TURN client vanishes silently (NAT rebind, ISP drop) sslh keeps the
# half-open socket forever. After 25 days we had 124 ESTAB sockets
# sitting with unread TLS ClientHellos and 25 CLOSE-WAIT — sslh's main
# loop had stopped consuming established sockets.
#
# 2026-05-17: A top-level ``keepalive: true`` was attempted and crashed
# sslh-select v2.3.1 at startup ("Unknown settings: keepalive"), which
# autoheal then turned into a restart loop and a prod outage. Root
# cause: ``keepalive`` is a per-``listen{}`` / per-``protocols{}`` option
# in sslh, NOT a top-level key. The block-level placement below is
# the correct syntax (added in upstream v1.18, 2016). With it set on
# every forwarded protocol, sslh enables SO_KEEPALIVE on the upstream
# socket and the kernel reaps dead peers via the standard
# ``net.ipv4.tcp_keepalive_*`` sysctls.
#
# We pin ``ghcr.io/yrutschle/sslh:2.3.1`` rather than ``:latest`` so
# config compatibility stays stable across deploys. Bump deliberately
# with a test run after.
verbose: 2;
foreground: true;
listen: ( { host: "0.0.0.0"; port: "443"; keepalive: true; } );
protocols: (
    { name: "tls";
      host: "__SET_HOST_IP__"; port: "5349";
      sni_hostnames: [ "__SET_TURN_SNI__" ];
      keepalive: true;
    },
    { name: "tls";
      host: "__SET_HOST_IP__"; port: "8444";
      keepalive: true;
    },
    { name: "anyprot";
      host: "__SET_HOST_IP__"; port: "8444";
      keepalive: true;
    }
);
