# Coturn config template — copy to ``turnserver.conf`` next to this file
# and substitute the marked values. The real ``turnserver.conf`` is
# gitignored because ``static-auth-secret`` is sensitive.
#
# Required substitutions (marked __SET_*__):
#   __SET_LISTENING_IP__  Internal/LAN IP of this host (e.g. 192.168.1.145
#                         on orrgate, 172.31.93.247 on orr1on). Bind
#                         target — coturn will listen on this IP.
#   __SET_EXTERNAL_IP__   Public reachable IP of this host (the address
#                         clients on the open internet hit). Required so
#                         coturn writes correct relay candidates into
#                         ICE responses.
#   __SET_STATIC_AUTH_SECRET__  Long random hex string. MUST match the
#                               ``TURN_SECRET`` value in concord's
#                               ``.env`` so the API server can mint
#                               valid time-limited credentials. Generate
#                               with: ``openssl rand -hex 32``
#   __SET_ALLOWED_PEER_IP__  The IP coturn is allowed to relay TO. For
#                            concord this is LiveKit's listening address
#                            on the same host or LAN.

no-udp
no-tcp
listening-port=0
tls-listening-port=5349

# Per-host. Use the LAN/internal IP that coturn should bind to.
listening-ip=__SET_LISTENING_IP__

# Certificate paths are mounted from ./certs into /etc/turn-certs inside
# the container (see docker-compose.yml). Drop the Let's Encrypt
# fullchain + privkey there. Never check certs/ into git.
cert=/etc/turn-certs/fullchain1.pem
pkey=/etc/turn-certs/privkey1.pem

# Per-host. Public IP advertised to ICE clients.
external-ip=__SET_EXTERNAL_IP__

# Relay port range (TLS-listening only; UDP/TCP disabled above).
min-port=49152
max-port=49200

# Shared-secret auth — must match TURN_SECRET in concord/.env.
use-auth-secret
static-auth-secret=__SET_STATIC_AUTH_SECRET__

fingerprint
no-multicast-peers
no-cli

# Default-deny private ranges to prevent relay-to-internal-services
# abuse; explicitly allow only the upstream peer (LiveKit).
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=192.168.0.0-192.168.255.255
allowed-peer-ip=__SET_ALLOWED_PEER_IP__

log-file=stdout
verbose
