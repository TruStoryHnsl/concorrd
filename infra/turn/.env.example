# Copy this file to ``.env`` next to it and fill in the values. The
# live ``.env`` is gitignored.
#
# Loaded automatically by ``docker compose up`` from the working dir.

# Public hostname the operator's Concord instance answers to. Used by
# the sslh healthcheck via extra_hosts -> 127.0.0.1, so it actually
# exercises sslh -> NPM -> conduwuit over the loopback chain rather
# than just an external HTTP probe.
CONCORD_PUBLIC_DOMAIN=chat.example.com
