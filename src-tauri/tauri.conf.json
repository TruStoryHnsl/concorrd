{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Concord",
  "version": "0.1.0",
  "identifier": "com.concord.chat",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Concord",
        "width": 1100,
        "height": 750,
        "minWidth": 420,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: wss: http: ws:; img-src 'self' https: data: blob:; media-src 'self' https: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "category": "SocialNetworking",
    "shortDescription": "Concord — decentralized chat",
    "longDescription": "Concord is a self-hosted, Matrix-based decentralized chat platform with voice channels, soundboard, and federation.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/tuwunel/**/*"
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "frameworks": []
    },
    "windows": {
      "wix": {
        "language": ["en-US"]
      }
    },
    "iOS": {
      "developmentTeam": null
    },
    "android": {
      "minSdkVersion": 24
    }
  },
  "plugins": {}
}
