{
    http_port 8080
    https_port 8443
}

{$SITE_ADDRESS} {
    # TLS via Let's Encrypt DNS-01 challenge against Cloudflare.
    #
    # Why DNS-01 (not HTTP-01): dev deployments (e.g. dev.concorrd.com) are
    # Tailscale-only — the gray-cloud Cloudflare DNS record points at a
    # 100.x Tailscale IP, so Let's Encrypt's HTTP-01 validation can't reach
    # the origin from the public internet. DNS-01 proves control by writing
    # a TXT record into the zone via the Cloudflare API, which works
    # regardless of origin reachability.
    #
    # Required env var:
    #   CLOUDFLARE_API_TOKEN — Cloudflare API token with Zone:Read + DNS:Edit
    #     scoped to the concorrd.com zone (or whatever zone the site uses).
    #     Minted at https://dash.cloudflare.com/profile/api-tokens. See
    #     .env.example for the full token-permissions rationale.
    #
    # Behaviour when CLOUDFLARE_API_TOKEN is unset: Caddy still attempts the
    # DNS-01 challenge, fails on missing credentials, and falls back to
    # serving the site without auto-TLS (or with self-signed certs on
    # internal domains). For TLS to work you MUST set this env var; the
    # dev Compose override loads it from .env automatically.
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }

    encode gzip

    header {
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(self), microphone=(self), geolocation=()"
    }

    request_body {
        max_size 20MB
    }

    # Matrix login — rate-limited via concord-api (2026-05-18 pentest F1).
    # Order matters: more specific path must come BEFORE the catch-all.
    handle /_matrix/client/*/login {
        reverse_proxy concord-api:8000 {
            header_up X-Forwarded-Proto {http.request.scheme}
            flush_interval -1
        }
    }

    # Matrix Client-Server API
    handle /_matrix/* {
        reverse_proxy conduwuit:6167 {
            flush_interval -1
        }
    }

    # Matrix well-known — see Caddyfile (production) for the full
    # rationale. tl;dr: these are static files, not dynamic endpoints.
    # Instance-agnostic via CONDUWUIT_SERVER_NAME env var so the dev
    # compose override works on any operator's deployment.
    handle /.well-known/matrix/server {
        header Content-Type "application/json"
        header Access-Control-Allow-Origin "*"
        respond `{"m.server":"{$CONDUWUIT_SERVER_NAME}:443"}` 200
    }
    handle /.well-known/matrix/client {
        header Content-Type "application/json"
        header Access-Control-Allow-Origin "*"
        respond `{"m.homeserver":{"base_url":"{$MATRIX_BASE_URL}"}}` 200
    }

    # Concord-specific well-known (INS-027) — dynamic endpoint served
    # by the Concord API container. See Caddyfile (production) for the
    # full rationale. CORS wildcard (INS-020) kept in sync with prod.
    handle /.well-known/concord/* {
        reverse_proxy concord-api:8000 {
            header_up X-Forwarded-Proto {http.request.scheme}
            header_down Access-Control-Allow-Origin "*"
            header_down Access-Control-Allow-Methods "GET, OPTIONS"
            header_down -Access-Control-Allow-Credentials
        }
    }

    # Concord API
    handle /api/* {
        reverse_proxy concord-api:8000 {
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }

    # Installed extension bundles (v0.4.0+). concord-api serves out of
    # <DATA_DIR>/extensions/<id>/ — iframes load index.html + relative
    # ./assets/ under this prefix. Matches prod Caddyfile behaviour.
    handle /ext/* {
        reverse_proxy concord-api:8000 {
            header_up X-Forwarded-Proto {http.request.scheme}
        }
    }

    # LiveKit WebSocket signaling
    handle_path /livekit/* {
        reverse_proxy livekit:7880 {
            header_up X-Forwarded-Proto {http.request.scheme}
            flush_interval -1
        }
    }

    # Desktop app downloads
    handle /downloads/* {
        header Content-Disposition "attachment"
        root * /srv
        file_server
    }

    # Vite HMR WebSocket — must come before the catch-all
    @hmr path /ws
    handle @hmr {
        reverse_proxy vite-dev:5173 {
            flush_interval -1
        }
    }

    # Proxy everything else to Vite dev server (HMR + SPA)
    handle {
        reverse_proxy vite-dev:5173 {
            flush_interval -1
        }
    }
}
