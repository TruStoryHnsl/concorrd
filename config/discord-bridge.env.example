# Discord Bridge Configuration (INS-024)
#
# Copy this file to discord-bridge.env and fill in the values.
# The .env file is gitignored (contains secrets).
#
# Discord Bot Token — obtained from https://discord.com/developers/applications
# Create a Bot, enable "Server Members Intent" and "Message Content Intent",
# then copy the token here.
DISCORD_BOT_TOKEN=

# Bridge homeserver URL — the tuwunel instance inside the Docker network.
# Default works for the standard docker-compose deployment.
HOMESERVER_URL=http://conduwuit:6167

# Bridge domain — must match the server_name in tuwunel config.
HOMESERVER_DOMAIN=concorrd.com

# Provisioning API shared secret — auto-generated by the enable flow.
# Only change if you need to manually rotate.
# PROVISIONING_SHARED_SECRET=

# Log level for mautrix-discord
LOG_LEVEL=info
