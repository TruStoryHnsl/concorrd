# Concord Environment Configuration
# The install wizard (./install.sh) will generate this file for you.
# Or copy to .env and fill in values manually: cp .env.example .env
#
# IMPORTANT: CONDUWUIT_SERVER_NAME cannot be changed after first run
# without wiping the database.

# ── Matrix Server Name ───────────────────────────────────────────────
# PERMANENT after first run. Appears in user IDs (@user:chat.example.com).
# Use your domain if you have one, otherwise something like "myserver.local".
# Changing this after the database is created will break everything.
CONDUWUIT_SERVER_NAME=chat.example.com
CONDUWUIT_REGISTRATION_TOKEN=generate-a-secure-random-token
CONDUWUIT_PORT=6167

# ── Instance Title ───────────────────────────────────────────────────
# Display name shown on login page, browser tab, and emails.
# Safe to change anytime — does not affect user IDs or Matrix identity.
INSTANCE_NAME=My Chat Server

# ── Network ──────────────────────────────────────────────────────────
# SITE_ADDRESS controls Caddy's behavior:
#   Domain (e.g. chat.example.com) → auto-HTTPS via Let's Encrypt
#   Port only (e.g. :8080)        → HTTP-only, no TLS
# Change this and restart to switch between modes.
SITE_ADDRESS=chat.example.com
HTTP_PORT=8080
# BIND_HOST controls which interface Docker listens on:
#   0.0.0.0   → all interfaces (default, reachable from network)
#   127.0.0.1 → localhost only (this machine)
BIND_HOST=
SITE_URL=https://chat.example.com

# ── Cloudflare Tunnel (automatic mode) ────────────────────────────
# Set by the installer when using automatic mode. The tunnel connects
# your domain to this server without port forwarding. Leave empty to
# disable (e.g. self-proxy or local-only modes).
# The installer also creates docker-compose.override.yml with the
# cloudflared service.
TUNNEL_TOKEN=

# ── Cloudflare API token (DNS-01 ACME for Caddy) ────────────────────
# Required when SITE_ADDRESS resolves to a hostname whose origin is NOT
# publicly reachable from the internet — for example a dev deployment
# whose Cloudflare DNS A record points at a Tailscale IP (gray-cloud,
# proxy OFF). In that topology Let's Encrypt's default HTTP-01 challenge
# cannot reach the origin to validate, so Caddy must use the DNS-01
# challenge instead. DNS-01 proves control of the domain by writing a
# transient TXT record into the zone via the Cloudflare API, which
# works regardless of where the origin actually lives.
#
# When to set:
#   - dev.concorrd.com served from orrion's Tailscale IP (Tailscale-only)
#   - Any homelab or internal-only origin behind a tunnel/VPN where the
#     public internet has no path to the host
#   - Any time you want certs issued without exposing port 80/443 to the
#     public internet for ACME validation
#
# When you DON'T need it: a fully public origin reachable on port 80 from
# the internet (Caddy's HTTP-01 default works fine — leave this blank).
#
# How to mint the token:
#   1. https://dash.cloudflare.com → My Profile → API Tokens → Create Token
#   2. Use the "Edit zone DNS" template, OR a custom token with:
#        Permissions: Zone → Zone: Read,  Zone → DNS: Edit
#        Zone Resources: Include → Specific zone → <your-zone>.com
#   3. (Recommended) restrict by client IP to your deployment host(s).
#
# Token scope rationale: Zone:Read + DNS:Edit on ONE zone is the minimum
# required for DNS-01 (Caddy needs to read the zone ID, then create/delete
# `_acme-challenge.<host>` TXT records). DO NOT use a global API key —
# blast radius if a global key leaks is total Cloudflare account
# compromise; blast radius if a single-zone DNS-edit token leaks is
# transient TXT records on one zone.
#
# Reading: the dev compose file (docker-compose.dev.yml) loads this into
# the web container's environment so Caddy can substitute it via
# `{env.CLOUDFLARE_API_TOKEN}` in the `tls { dns cloudflare ... }` block.
CLOUDFLARE_API_TOKEN=

# ── Federation (Instance-to-Instance) ───────────────────────────────
# Federation settings moved out of .env in Concord 0.2.0. The allowlist
# is now managed at runtime via the admin UI (Settings → Admin → Federation)
# and persisted to `config/tuwunel.toml`, which is bind-mounted into both
# the conduwuit and concord-api containers. Changes apply via an automated
# Matrix server restart (~10-15s downtime) triggered from the admin panel.
#
# Edit `config/tuwunel.toml` directly for advanced regex patterns, or use
# the admin UI for plain hostnames. To re-enable federation after changing
# the file outside the UI, run `docker compose restart conduwuit`.
#
# The three legacy env vars below are no longer read by docker-compose.yml.
# If you have them set from a pre-0.2.0 install, run:
#     ./scripts/migrate-federation-config.sh
# to migrate their values into config/tuwunel.toml automatically.
#
# CONDUWUIT_ALLOW_FEDERATION=true
# CONDUWUIT_FORBIDDEN_REMOTE_SERVER_NAMES='[".*"]'
# CONDUWUIT_ALLOWED_REMOTE_SERVER_NAMES='[]'

# ── LiveKit (Voice/Video) ───────────────────────────────────────────
# Generate key/secret with: openssl rand -base64 32
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# ── TURN Relay (bundled coturn) ─────────────────────────────────────
# Concord bundles a coturn TURN server for NAT traversal. This is
# required for voice to work when users are behind NAT or when the
# server is behind a CDN (Cloudflare, etc.) that blocks UDP.
#
# TURN_SECRET: shared secret for credential generation (auto-generated
#   by install.sh — must match between coturn and the API server).
TURN_SECRET=generate-a-secure-random-token

# TURN_DOMAIN and TURN_HOST are now AUTO-DERIVED from PUBLIC_BASE_URL
# (above). The Concord API computes:
#
#   INSTANCE_DOMAIN = hostname-of(PUBLIC_BASE_URL)
#   TURN_DOMAIN     = INSTANCE_DOMAIN
#   TURN_HOST       = turn.${INSTANCE_DOMAIN}
#
# You should NOT need to set TURN_DOMAIN or TURN_HOST here. They exist
# only as explicit overrides for unusual deployments (e.g. a TURN host
# on a different parent domain than the rest of the instance).
#
# IMPORTANT: a TURN_HOST value that resolves to a private/loopback IPv4
# address (192.168.x.x, 10.x.x.x, 172.16-31.x.x, 127.x.x.x) is IGNORED
# at runtime — it would advertise an LAN address to off-LAN browsers
# as their ICE relay URL, which is unrouteable. Use a public DNS name
# or unset TURN_HOST and let the derivation do its job.
#
# TURN_EXTERNAL_IP is handled automatically by install.sh in
# docker-compose.override.yml (only needed when behind NAT).
# TURN_DOMAIN=     # leave unset; derived from PUBLIC_BASE_URL
# TURN_HOST=       # leave unset; derived as turn.<INSTANCE_DOMAIN>

# ── Admin ────────────────────────────────────────────────────────────
# Comma-separated Matrix user IDs with global admin access
ADMIN_USER_IDS=@admin:chat.example.com

# ── SMTP (optional, enables email invites) ──────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Freesound API (optional, sound effect library) ──────────────────
# Get a key at https://freesound.org/apiv2/apply
FREESOUND_API_KEY=

# ── INS-028: GitHub bug report integration (optional) ──────────────
# When set, each bug report submitted via BugReportModal is mirrored
# to a GitHub issue on the repo named by GITHUB_BUG_REPORT_REPO.
# Leave empty (the default) to disable the mirror — bug reports will
# still be stored in the local DB and surfaced in the admin panel.
#
# Token scope: a FINE-GRAINED personal access token with the single
# permission `Issues: Read and write` on the one repository named in
# GITHUB_BUG_REPORT_REPO. NOT a classic `repo`-scoped token — the
# classic scope is far too broad. Blast radius if this token leaks:
# an attacker can create and edit issues on one repo. They cannot
# read private code, modify workflows, touch the homeserver,
# LiveKit, or any other Concord service. Rotation runbook lives at
# docs/deployment/github_bug_report_token.md.
#
# Privacy: the mirror only sends the user-typed title + description
# to GitHub. The system_info JSON (userAgent, URL, voice state) is
# kept in the local bug_reports table and never leaves the server.
GITHUB_BUG_REPORT_TOKEN=
GITHUB_BUG_REPORT_REPO=TruStoryHnsl/concord

# ── Advanced: LiveKit port overrides ────────────────────────────────
# See docs/voice/port-coherence.md. These advisory defaults must stay
# in sync with config/livekit.yaml rtc.port_range_start..port_range_end
# AND the docker-compose.yml livekit.ports[] container-side range.
# CI's config-lint job enforces this on every PR.
#LIVEKIT_TURN_PORT=3478
#LIVEKIT_TCP_PORT=7881
#LIVEKIT_UDP_START=50000
#LIVEKIT_UDP_END=50100
