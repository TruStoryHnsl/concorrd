# Concord Environment Configuration
# The install wizard (./install.sh) will generate this file for you.
# Or copy to .env and fill in values manually: cp .env.example .env
#
# IMPORTANT: CONDUWUIT_SERVER_NAME cannot be changed after first run
# without wiping the database.

# ── Matrix Homeserver ────────────────────────────────────────────────
CONDUWUIT_SERVER_NAME=example.com
CONDUWUIT_REGISTRATION_TOKEN=generate-a-secure-random-token
CONDUWUIT_PORT=6167

# ── LiveKit (Voice/Video) ───────────────────────────────────────────
# Generate key/secret with: openssl rand -base64 32
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret
LIVEKIT_TURN_DOMAIN=example.com

# ── TURN Relay (optional, improves voice behind strict NATs) ────────
# Free credentials at https://www.metered.ca/
METERED_APP_NAME=
METERED_API_KEY=

# ── Admin ────────────────────────────────────────────────────────────
# Comma-separated Matrix user IDs with global admin access
ADMIN_USER_IDS=@admin:example.com

# ── SMTP (optional, enables email invites) ──────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SITE_URL=http://example.com:8080

# ── Freesound API (optional, sound effect library) ──────────────────
# Get a key at https://freesound.org/apiv2/apply
FREESOUND_API_KEY=

# ── Instance Branding ──────────────────────────────────────────────────
# Name shown on login page, browser tab, and emails (admin can change later)
INSTANCE_NAME=Concord

# ── Ports ──────────────────────────────────────────────────────────────
NGINX_HTTP_PORT=8080
# Override LiveKit host ports if running multiple instances on one host
#LIVEKIT_TURN_PORT=3478
#LIVEKIT_TCP_PORT=7881
#LIVEKIT_UDP_START=50000
#LIVEKIT_UDP_END=50100
